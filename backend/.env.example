# =====================================================================
# KrishiAI Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
#
# After filling in values, run: python check_env.py
# to validate all settings and test external service connectivity.
# =====================================================================

# ── Supabase (required) ──────────────────────────────────────────────
# Get from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
# Service role key (admin — keep secret, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── MQTT Broker (HiveMQ Cloud recommended) ───────────────────────────
# Free cluster: https://www.hivemq.com/mqtt-cloud-broker/
# For development you can use the public broker (no credentials needed):
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false
# For HiveMQ Cloud (TLS on port 8883):
# MQTT_BROKER=your-cluster-id.s2.eu.hivemq.cloud
# MQTT_PORT=8883
# MQTT_USERNAME=your_hivemq_username
# MQTT_PASSWORD=your_hivemq_password
# MQTT_USE_TLS=true

# ── Twilio (SMS / OTP / Voice / WhatsApp) ────────────────────────────
# Get from https://console.twilio.com → Account Info
# Free trial: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio phone number with SMS + Voice capability:
TWILIO_PHONE_NUMBER=+1234567890
# WhatsApp sandbox number (or approved business number):
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Google Maps API ──────────────────────────────────────────────────
# Enable in Google Cloud Console:
#   - Maps JavaScript API (for frontend)
#   - Geocoding API (for reverse geocoding in backend)
# https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── OpenWeather API ──────────────────────────────────────────────────
# Free tier (1,000 calls/day): https://openweathermap.org/api
# Subscribe to "One Call API 3.0" for extended forecasts.
OPENWEATHER_API_KEY=your_openweather_api_key

# ── Gemini AI (Google GenerativeAI) ──────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
# Used for: daily farm log generation, AI summaries
VITE_GEMINI_API_KEY=your_gemini_api_key

# ── App / Backend URL ─────────────────────────────────────────────────
# Public URL of this backend server (used for Twilio voice webhooks)
# In development: http://localhost:8000
# In production: https://your-api-domain.com
APP_BASE_URL=http://localhost:8000

# ── PostgreSQL (legacy mandi prices database) ────────────────────────
# Required only for: python fetch_market_prices.py and python train_model.py
# Not needed if using Supabase for all data.
DB_NAME=SmartAgriDB
DB_USER=postgres
DB_PASS=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# ── data.gov.in API (Mandi prices) ───────────────────────────────────
# Free registration: https://data.gov.in/
# Required only for fetching live APMC mandi prices.
API_KEY=your_datagov_api_key
